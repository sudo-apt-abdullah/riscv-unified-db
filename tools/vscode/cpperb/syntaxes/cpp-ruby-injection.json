{
  "name": "C++ (Ruby - ERB)",
  "scopeName": "source.cpp.erb",
  "fileTypes": ["h.erb", "hxx.erb", "hpp.erb", "cpp.erb", "cxx.erb"],
  "injections": {
    "L:source.cpp.erb": {
      "patterns": [
        {
          "include": "#comment"
        },
        {
          "include": "#tags"
        }
      ]
    }
  },
  "patterns": [
    {
      "include": "source.cpp"
    }
  ],
  "repository": {
    "comment": {
      "patterns": [
        {
          "begin": "<%+#",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.comment.begin.erb"
            }
          },
          "end": "%>",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.comment.end.erb"
            }
          },
          "name": "comment.block.erb"
        }
      ]
    },
    "tags": {
      "patterns": [
        {
          "comment": "ERB block",
          "begin": "<%+(?!>)[-=]?",
          "beginCaptures": {
            "0": {
              "name": "punctuation.section.embedded.begin.erb"
            }
          },
          "end": "(-?)%>",
          "endCaptures": {
            "0": {
              "name": "punctuation.section.embedded.end.erb"
            },
            "1": {
              "name": "punctuation.whitespace.embedded.erb"
            }
          },
          "name": "meta.embedded.block.erb",
          "contentName": "source.ruby.embedded.erb",
          "patterns": [
            {
              "captures": {
                "1": {
                  "name": "punctuation.definition.comment.erb"
                }
              },
              "match": "(#).*?(?=-?%>)",
              "name": "comment.line.number-sign.erb"
            },
            {
              "include": "source.ruby"
            }
          ]
        }
      ]
    }
  }
}
