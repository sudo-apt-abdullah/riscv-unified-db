{
  "name": "yamlidl-vscode",
  "displayName": "YAML with IDL Injection",
  "description": "Syntax highlighting for YAML files with IDL code in string values where keys end with parentheses",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.91.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/riscv/riscv-unified-db",
    "directory": "yamlidl"
  },
  "publisher": "HowerLimited",
  "contributes": {
    "grammars": [
      {
        "scopeName": "yaml.idl.injection",
        "path": "./syntaxes/yaml-idl-injection.json",
        "injectTo": [
          "source.yaml"
        ],
        "embeddedLanguages": {
          "meta.embedded.block.idl": "idl",
          "meta.embedded.block.asciidoc": "asciidoc"
        }
      }
    ]
  }
}
