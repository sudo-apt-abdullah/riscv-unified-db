# yaml-language-server: $schema=../../../../schemas/inst_schema.json
<%-
  raise "'size' must be defined as 'b', 'h', 'w', or 'd'" unless %w[b h w d].include?(size)
  raise "'rl' must be defined as true or false" unless [true, false].include?(rl)

  size_info = {
    "b" => { funct3: "000", long_name_suffix: "Byte" },
    "h" => { funct3: "001", long_name_suffix: "Halfword" },
    "w" => { funct3: "010", long_name_suffix: "Word" },
    "d" => { funct3: "011", long_name_suffix: "Doubleword" }
  }

  current_size = size_info[size]

  aq_rl_suffix = rl ? ".aqrl" : ".aq"
  rl_bit = rl ? "1" : "0"
  acquire_suffix = " Acquire"
  release_suffix = rl ? " Release" : ""
-%>

$schema: "inst_schema.json#"
kind: instruction
name: l<%= size %><%= aq_rl_suffix %>
long_name: Load <%= current_size[:long_name_suffix] %><%= acquire_suffix %><%= release_suffix %>
description: |
  No description available.
definedBy:
  extension:
    name: Zalasr
assembly: xd, (xs1)
encoding:
  match: 001101<%= rl_bit %>00000-----<%= current_size[:funct3] %>-----0101111
  variables:
    - name: xs1
      location: 19-15
    - name: xd
      location: 11-7
access:
  s: always
  u: always
  vs: always
  vu: always
data_independent_timing: false
operation(): |

# SPDX-SnippetBegin
# SPDX-FileCopyrightText: 2017-2025 Contributors to the RISCV Sail Model <https://github.com/riscv/sail-riscv/blob/master/LICENCE>
# SPDX-License-Identifier: BSD-2-Clause
sail(): |
  {
    let offset : xlenbits = sign_extend(imm);
    /* Get the address, X(rs1) + offset.
       Some extensions perform additional checks on address validity. */
    match ext_data_get_addr(rs1, offset, Read(Data), width) {
      Ext_DataAddr_Error(e)  => { ext_handle_data_check_error(e); RETIRE_FAIL },
      Ext_DataAddr_OK(vaddr) =>
        if   check_misaligned(vaddr, width)
        then { handle_mem_exception(vaddr, E_Load_Addr_Align()); RETIRE_FAIL }
        else match translateAddr(vaddr, Read(Data)) {
          TR_Failure(e, _) => { handle_mem_exception(vaddr, e); RETIRE_FAIL },
          TR_Address(paddr, _) =>
            match (width) {
              BYTE =>
                process_load(rd, vaddr, mem_read(Read(Data), paddr, 1, aq, rl, false), is_unsigned),
              HALF =>
                process_load(rd, vaddr, mem_read(Read(Data), paddr, 2, aq, rl, false), is_unsigned),
              WORD =>
                process_load(rd, vaddr, mem_read(Read(Data), paddr, 4, aq, rl, false), is_unsigned),
              DOUBLE if sizeof(xlen) >= 64 =>
                process_load(rd, vaddr, mem_read(Read(Data), paddr, 8, aq, rl, false), is_unsigned),
              _ => report_invalid_width(__FILE__, __LINE__, width, "load")
            }
        }
    }
  }

# SPDX-SnippetEnd
